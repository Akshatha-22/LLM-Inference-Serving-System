"""
benchmarks/run_baseline_simple.py
Day 2: Simple baseline measurement — no complex imports
Run this FIRST to verify everything works.
"""

import time
import torch
from transformers import GPT2LMHeadModel, GPT2Tokenizer

print("=" * 60)
print("BASELINE BENCHMARK — Day 2 (Simple Version)")
print("=" * 60)

# Step 1: Load tokenizer
print("\n1. Loading tokenizer...")
tokenizer = GPT2Tokenizer.from_pretrained("gpt2")
tokenizer.pad_token = tokenizer.eos_token
print("   ✓ Tokenizer loaded")

# Step 2: Load model
print("\n2. Loading GPT-2 Small (124M parameters)...")
start_load = time.time()
model = GPT2LMHeadModel.from_pretrained("gpt2")
model.eval()
load_time = time.time() - start_load
print(f"   ✓ Model loaded in {load_time:.2f} seconds")

# Step 3: Count parameters
param_count = sum(p.numel() for p in model.parameters())
print(f"   ✓ Parameters: {param_count:,}")

# Step 4: Memory usage
import psutil
import os
process = psutil.Process(os.getpid())
memory_mb = process.memory_info().rss / 1024 / 1024
print(f"   ✓ Memory: {memory_mb:.1f} MB")

# Step 5: Run baseline generation
print("\n3. Running baseline generation (5 runs, 50 tokens each)...")
print("-" * 40)

prompt = "The future of artificial intelligence is"
max_new_tokens = 50
speeds = []

for i in range(5):
    inputs = tokenizer(prompt, return_tensors="pt")
    input_length = inputs["input_ids"].shape[1]
    
    start_time = time.perf_counter()
    
    with torch.no_grad():
        outputs = model.generate(
            inputs["input_ids"],
            max_new_tokens=max_new_tokens,
            do_sample=False,
            pad_token_id=tokenizer.eos_token_id,
            use_cache=True,
        )
    
    end_time = time.perf_counter()
    
    total_tokens = outputs.shape[1] - input_length
    elapsed = end_time - start_time
    tokens_per_sec = total_tokens / elapsed
    speeds.append(tokens_per_sec)
    
    print(f"   Run {i+1}: {tokens_per_sec:.2f} tok/s ({elapsed:.2f}s)")

# Step 6: Calculate statistics
avg_speed = sum(speeds) / len(speeds)
min_speed = min(speeds)
max_speed = max(speeds)
std_speed = (sum((s - avg_speed)**2 for s in speeds) / len(speeds)) ** 0.5

# Step 7: Sample output
print("\n4. Sample generation:")
result = model.generate(
    tokenizer(prompt, return_tensors="pt")["input_ids"],
    max_new_tokens=30,
    do_sample=False,
    pad_token_id=tokenizer.eos_token_id,
)
generated_text = tokenizer.decode(result[0], skip_special_tokens=True)
print(f"   Prompt: '{prompt}'")
print(f"   Output: {generated_text[:200]}...")

# Step 8: Final results
print("\n" + "=" * 60)
print("✅ BASELINE RESULTS")
print("=" * 60)
print(f"   Load time: {load_time:.2f}s")
print(f"   Memory: {memory_mb:.1f} MB")
print(f"   Tokens/sec (avg): {avg_speed:.2f}")
print(f"   Tokens/sec (min): {min_speed:.2f}")
print(f"   Tokens/sec (max): {max_speed:.2f}")
print(f"   Std deviation: {std_speed:.2f}")
print("\n   🎯 This is your North Star baseline!")
print(f"   → Every optimization will be compared to {avg_speed:.2f} tok/s")